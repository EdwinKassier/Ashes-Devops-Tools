{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyOutsideAllowedRegions",
      "Effect": "Deny",
      "NotAction": [
        "iam:*",
        "organizations:*",
        "route53:*",
        "route53domains:*",
        "cloudfront:*",
        "waf:*",
        "wafv2:*",
        "shield:*",
        "globalaccelerator:*",
        "support:*",
        "trustedadvisor:*",
        "artifact:*",
        "budgets:*",
        "ce:*",
        "cur:*",
        "account:*",
        "savingsplans:*",
        "sso:*",
        "sso-directory:*",
        "identitystore:*",
        "health:*",
        "kms:*"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:RequestedRegion": ${allowed_regions}
        },
        "ArnNotLike": {
          "aws:PrincipalArn": [
            "${terraform_run_role_arn}",
            "${break_glass_role_arn}"
          ]
        }
      }
    }
  ]
}
