# Copy to terraform.tfvars and fill in. Inputs marked REQUIRED have no usable
# default — you MUST supply them. Select the workspace for this environment with
# TF_WORKSPACE, e.g. `export TF_WORKSPACE=aws-workload-dev`.

# REQUIRED — Terraform Cloud org that owns this root's workspace and the
# aws-organization + aws-network workspaces it reads. Usually passed to
# `terraform init` via backend.hcl / TF_CLI_ARGS_init rather than here.
# tfc_organization = "your-tfc-org-name"

# Optional — upstream workspaces this root reads remote state from.
organization_workspace_name = "aws-organization"
network_workspace_name      = "aws-network"

# REQUIRED — key into the aws-organization account_role_arns map for THIS env's
# workload account. Both providers assume this role.
# workload_account_key = "workload_dev"

# Optional — deploy region (also the region the workload-account role is assumed
# in and the key used to pick the regional IPAM pool) and the enabled regions.
aws_region          = "eu-west-2"
aws_enabled_regions = ["eu-west-2"]

# Optional — spoke VPC CIDR (subnet math; actual CIDR allocated from shared IPAM).
vpc_cidr = "10.20.0.0/16"

# REQUIRED — central log-archive bucket name. MUST match the name the
# aws-organization and aws-network roots use (cross-root naming contract).
# log_archive_bucket_name = "ashes-org-log-archive"

# REQUIRED — IAM role AWS Config assumes to record resources in this account.
# config_role_arn = "arn:aws:iam::222222222222:role/config-recorder"

# CMK for default EBS encryption + Session Manager. Empty leaves EBS on the
# AWS-managed key. NOTE: the stage keeps Systems Manager ON, and SSM requires a
# non-empty CMK (Session Manager sessions must be KMS-encrypted), so in practice
# you MUST supply a real key ARN here.
# kms_key_arn = "arn:aws:kms:eu-west-2:222222222222:key/abcd-1234"

# Optional — deploy the per-workload edge (CloudFront + WAF in us-east-1).
enable_edge = false

# Optional — workload / cross-account IAM roles.
workload_roles = {}
